{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/.mempalace/hooks/mempal_save_hook.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "__HOME__/.mempalace/hooks/mempal_precompact_hook.sh",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "autoMemoryEnabled": false
}
